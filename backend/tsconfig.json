{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@screens/types": ["../packages/types/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../packages/types/src/**/*"],
  "exclude": ["node_modules"]
}
